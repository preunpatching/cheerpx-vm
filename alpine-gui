FROM docker.io/i386/alpine:3.17
# Add a user
RUN adduser -D user && echo 'user:password' | chpasswd
# Allow root login
RUN echo 'root:password' | chpasswd
# Install packages
RUN apk update && apk add \
    alpine-base \
    udev-init-scripts \
    udev-init-scripts-openrc \
    eudev \
    xorg-server \
    xf86-input-libinput \
    lightdm \
    $(apk search -q 'lxqt*') \
    falkon \
    kvantum \
    lximage-qt \
    menu-cache \
    obconf-qt \
    openbox \
    pavucontrol-qt \
    pcmanfm-qt \
    qalc \
    qps \
    qterminal \
    qtermwidget \
    qtxdg-tools \
    xdg-desktop-portal \
    screengrab \
    desktop-file-utils \
    shared-mime-info \
    adwaita-icon-theme \
    gvfs \
    font-dejavu \
    xrandr \
    xev \
    bash \
    dbus-x11
# Setup the init script
RUN update-desktop-database -q && update-mime-database /usr/share/mime
RUN rc-update add bootmisc boot && rc-update add udev sysinit && rc-update add udev-trigger sysinit && rc-update add udev-settle sysinit && rc-update add udev-postmount default && rc-update add dbus default && rc-update add lightdm default
RUN sed -i "s/#autologin-user=/autologin-user=user/g" /etc/lightdm/lightdm.conf && \
    sed -i "s/#autologin-user-timeout=0/autologin-user-timeout=0/g" /etc/lightdm/lightdm.conf && \
    sed -i "s/#autologin-session=/autologin-session=lxqt/g" /etc/lightdm/lightdm.conf
# Add a script to support display autoresizing
RUN printf "while true; do\n    xev -root -event randr | while read line; do killall -q xev; done\n    xrandr --output None-0 --off\n    xrandr --auto\n    if [ -f ~/.fehbg ]; then\n        ~/.fehbg &\n    fi\ndone &" > /etc/X11/xinit/xinitrc.d/99-screen-resize.sh
CMD [ "/bin/sh" ]
# Warning: if deployed through built-in deploy workflow, do not remove these lines below!
