FROM docker.io/i386/alpine:latest
# Add a user
RUN adduser -D user && echo 'user:password' | chpasswd
# Allow root login
RUN echo 'root:password' | chpasswd
# Install required packages
RUN apk update && apk add --no-cache alpine-base bash bash-completion bat build-base busybox-extras bzip2 cmake curl docs dust eza fd findutils fish fx fzf gawk git gzip httpie hexyl jo jq lua5.4 luarocks man-db mc micro nano ncdu neovim nodejs npm openssl python3 py3-pip ripgrep sd sed sqlite starship tig tree unzip vim wget xz yq zip zoxide
# Set up Starship
USER user
WORKDIR /home/user
RUN echo 'eval "$(starship init bash)"' > .bashrc
RUN mkdir -p .config/fish
RUN echo 'starship init fish | source' > .config/fish/config.fish
RUN chmod 755 .bashrc
RUN chmod 755 .config/fish/config.fish
CMD [ "/usr/bin/fish" ]
### <<<IMAGE CONFIGURATION START>>>
### CMD: ["/usr/bin/fish", "-l"]
### ENV: ["HOME=/home/user", "TERM=xterm", "USER=user", "SHELL=/usr/bin/fish", "EDITOR=micro"]
### CWD: "/home/user"
### UID: 1000
### GID: 1000
### <<<IMAGE CONFIGURATION END>>>